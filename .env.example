# .env.example
# Copia este archivo como .env.local y completa los valores reales
# NUNCA commitees .env.local al repositorio

# ── Base de datos (AWS RDS PostgreSQL) ──────────────────
DATABASE_URL="postgresql://usuario:contraseña@tu-endpoint.rds.amazonaws.com:5432/valentinajimenez"

# ── NextAuth ─────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secreto-seguro-aqui"
NEXTAUTH_URL="https://tudominio.com"
# En desarrollo local usar: http://localhost:3000

# ── AWS SES (emails) ─────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
# Email verificado en SES (debe estar verificado en la consola AWS)
SES_FROM_EMAIL="noreply@tudominio.com"

# ── AWS S3 (galería de imágenes) ─────────────────────────
# El bucket que creaste con terraform o manualmente.
# En PRODUCCIÓN (EC2 con Instance Profile) NO necesitas
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: el SDK usa el
# rol de la instancia automáticamente.
AWS_S3_BUCKET="appointment-scheduling-assets"
# Opcional: dominio público (p.ej. CloudFront) para servir las imágenes.
# Si no se define, usa la URL nativa s3.<region>.amazonaws.com.
# AWS_S3_PUBLIC_BASE_URL="https://cdn.tudominio.com"

# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="valentinajimenez"
NEXT_PUBLIC_APP_URL="https://tudominio.com"

# ── WhatsApp (links con mensaje precargado) ──────────────
# Número en formato internacional, sin + ni espacios (para wa.me/).
NEXT_PUBLIC_WHATSAPP_NUMBER="573001790511"
# Mensaje que se precarga al abrir el chat.
NEXT_PUBLIC_WHATSAPP_MESSAGE="¡Hola! Vengo de su sitio web y me gustaría más información."

# Apagar emails (desarrollo / sin SES configurado)
ENABLE_EMAILS=false