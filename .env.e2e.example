# .env.e2e.example
# Copia a .env.e2e (gitignored). Configura una base de datos de PRUEBA dedicada
# — NUNCA la de desarrollo ni producción (el seed se ejecuta sobre ella).

# Base de datos de prueba. Ej. local con el Postgres de docker compose:
#   crea una DB aparte:  createdb vj_e2e   (o CREATE DATABASE vj_e2e;)
E2E_DATABASE_URL="postgresql://valentinajimenez:devpassword@localhost:5432/vj_e2e"

# Secreto de NextAuth para el server de prueba (cualquier string).
NEXTAUTH_SECRET="e2e-test-secret-not-for-prod"

# Puerto del server de prueba (debe coincidir con playwright.config.ts).
E2E_PORT="3100"

# Credenciales del admin sembrado (de prisma/seed.ts) — para los flujos admin:
#   email: admin@vjbeautystudio.com
#   pass:  Admin123!
