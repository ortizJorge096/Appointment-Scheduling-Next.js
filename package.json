{
  "name": "appointment-scheduling-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "format": "prettier --check --ignore-unknown src/",
    "format:fix": "prettier --write --ignore-unknown src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "next build && playwright test",
    "test:e2e:ui": "next build && playwright test --ui",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio",
    "reminders": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/send-reminders.ts",
    "reminders:2h": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/send-reminders-2h.ts",
    "follow-ups": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/send-follow-ups.ts",
    "fill-day": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/fill-day.ts",
    "clear-demo": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/clear-demo.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^16.4.5",
    "next": "^15.3.3",
    "next-auth": "^4.24.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.1",
    "googleapis": "^144.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.3.3",
    "jsdom": "^26.0.0",
    "postcss": "^8.4.38",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^8.0.0",
    "vitest": "4.1.8"
  }
