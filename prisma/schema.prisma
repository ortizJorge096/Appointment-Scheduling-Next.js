// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pg_trgm powers the GIN indexes that accelerate the admin list's ILIKE search.
  extensions = [pg_trgm]
}

// ─────────────────────────────────────────
// USERS (admin)
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  // Deactivated admins can't log in and their active sessions are invalidated,
  // but the row persists so audit history keeps their name.
  isActive  Boolean  @default(true)
  // Last successful login (shown in the admin-management list).
  lastLoginAt DateTime?
  // Bumped on every password change; embedded in the JWT so tokens issued
  // before the change are rejected → forces re-login on other devices.
  passwordChangedAt DateTime?
  // Forces a password change before using the panel — set when an admin creates
  // the user or resets its password; cleared when the user changes it. Enforced
  // by the protected layout guard.
  mustChangePassword Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

enum Role {
  ADMIN
  SUPER_ADMIN
  RECEPCIONISTA
  SOLO_LECTURA
}

// ─────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────

model Client {
  id           String        @id @default(cuid())
  name         String
  // Optional: in Postgres a unique index allows multiple NULLs, so several
  // clients without email never collide, while real emails stay unique.
  email        String?       @unique
  phone        String?
  // Canonical phone (normalizePhone → 57XXXXXXXXXX): the client's identity key.
  // @unique so one phone = one client; nullable so admin-created clients without
  // a phone don't collide (Postgres allows multiple NULLs under a unique index).
  phoneNormalized String?    @unique
  notes        String?       // allergies, preferences, internal notes
  // Soft-delete (archive): hidden from the active directory but kept, with its
  // appointment links intact, so history is never lost. Reversible.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  @@index([email])
  @@map("clients")
}

// ─────────────────────────────────────────
// SERVICE CATEGORIES
// These used to be a hardcoded enum; now they live in the DB so they can be
// created/edited/deleted from the admin panel without touching code.
// `slug` is the stable key used in URLs (?categoria=...) and for grouping.
// `icon` stores the key of a predefined icon set (see ICON_KEYS).
// Soft delete: rows are never physically removed, to preserve history.
// ─────────────────────────────────────────

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  slug          String         @unique
  description   String?
  icon          String         @default("promo")
  order         Int            @default(0)
  isActive      Boolean        @default(true)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  services      Service[]
  galleryImages GalleryImage[]
  @@index([isActive])
  @@index([deletedAt])
  @@map("categories")
}

// ─────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────

model Service {
  id              String              @id @default(cuid())
  name            String              @unique
  description     String?
  categoryId      String?
  category        Category?           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  price           Int
  durationMinutes Int
  isActive        Boolean             @default(true)
  order           Int                 @default(0)
  // Soft delete: the service disappears from the catalog but the row persists,
  // so historical appointments keep their reference and name.
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  appointments    Appointment[]
  appointmentServices AppointmentService[]
  @@index([categoryId])
  @@index([deletedAt])
  @@map("services")
}

// ─────────────────────────────────────────
// VIP DISCOUNT (multi-service)
// Configurable rule: from N services selected in a single appointment
// (across any category), a tiered discount percentage is applied.
// Editable from the admin panel, without touching code.
// ─────────────────────────────────────────

model VipDiscountConfig {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  @@map("vip_discount_config")
}

model VipDiscountTier {
  id          String @id @default(cuid())
  minServices Int    @unique // how many services this tier starts applying at
  discountPct Int    // discount percentage (0-100)
  @@map("vip_discount_tiers")
}

// ─────────────────────────────────────────
// PROFESSIONALS
// Each professional can serve one appointment at a time; the studio's total
// capacity in a time slot = number of active professionals without an
// appointment overlapping that range.
// ─────────────────────────────────────────

model Professional {
  id           String        @id @default(cuid())
  name         String
  specialty    String?
  rating       Float         @default(5.0)
  reviewCount  Int           @default(0)
  isActive     Boolean       @default(true)
  order        Int           @default(0)
  // Soft delete: a deleted professional disappears from the admin list, the
  // public booking flow and availability, but the row persists so historical
  // appointments keep their professionalId reference intact.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  @@index([isActive])
  @@index([deletedAt])
  @@map("professionals")
}

// Toggle (singleton): whether /agendar lets the client pick a professional.
// When off, the booking form never sends professionalId — the existing
// "Primera disponible" auto-assignment in /api/appointments already covers it.
model BookingSettings {
  id                  String   @id @default(cuid())
  showProfessionalStep Boolean @default(false)
  // How many days into the future clients can book (booking horizon).
  // Drives the date strip in /agendar. Editable from the admin (7–365).
  maxAdvanceDays      Int      @default(90)
  updatedAt           DateTime @updatedAt
  @@map("booking_settings")
}

// ─────────────────────────────────────────
// LANDING METRICS (singleton)
// Numeric indicators for the Home/About sections, editable from the admin
// panel so code stays untouched. `servicesCount` is NOT stored here: it's
// derived live from the catalog (active services) so it never drifts.
// ─────────────────────────────────────────
model LandingStats {
  id                String   @id @default(cuid())
  appointmentsCount Int      @default(300) // renders as "+300 Citas realizadas"
  clientsCount      Int      @default(180) // renders as "+180 Clientas satisfechas"
  yearsExperience   Int      @default(3)   // renders as "+3 Años de experiencia"
  rating            Float    @default(4.8) // renders as "4.8★ Calificación"
  updatedAt         DateTime @updatedAt
  @@map("landing_stats")
}

// ─────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────

model Appointment {
  id                 String            @id @default(cuid())
  // Client data (denormalized so info isn't lost if the client record changes)
  clientName         String
  clientEmail        String?
  clientPhone        String
  // Reference to the client profile (optional: auto-linked if one exists)
  clientId           String?
  client             Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId          String            // primary service (always set for backward compat)
  service            Service           @relation(fields: [serviceId], references: [id])
  services           AppointmentService[] // all services (for multi-service VIP bookings)
  totalDurationMinutes Int             // sum of all service durations
  discountPercent    Int               @default(0) // applied VIP discount % (snapshot at confirmation)
  // Assigned professional. Null = "First available" was chosen but couldn't be
  // resolved (shouldn't happen in the normal flow; the server assigns the first
  // free professional at the time the appointment is created).
  professionalId     String?
  professional       Professional?     @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  date               DateTime
  startTime          String
  endTime            String
  status             AppointmentStatus @default(PENDING)
  // Appointment source
  source             AppointmentSource @default(ONLINE)
  // Provenance, set explicitly at creation (no field-combination heuristics):
  // PUBLIC = client self-booked, MANUAL = admin "Cita próxima", VIP = multi-
  // service package, PAST = retroactive "Cita pasada". Legacy rows backfilled
  // in the migration (source != ONLINE → MANUAL, else PUBLIC).
  origin             AppointmentOrigin @default(PUBLIC)
  // Payment
  paymentStatus      PaymentStatus     @default(PENDING)
  paymentMethod      PaymentMethod?
  amountPaid         Int?              // in Colombian pesos
  // Extras: additional charges on top of the service price (products, extra
  // services). Multiple per appointment, editable from the detail view.
  extras             AppointmentExtra[]
  // Manual discount applied by the admin (manual appointments). Independent of
  // the public flow's VIP discountPercent. precioFinal = subtotal − discount.
  descuentoTipo      DiscountType?     // null = no discount
  descuentoValor     Int?              // % (0–100) or fixed COP, per descuentoTipo
  descuentoMotivo    String?           // internal, optional (e.g. "Cliente frecuente")
  precioFinal        Int?              // total to charge after discount (snapshot, COP)
  notes              String?
  cancelToken        String            @unique @default(cuid())
  calendarEventId    String?
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  reminder2hSentAt   DateTime?
  followUpSentAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  @@index([date])
  @@index([clientEmail])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([professionalId])
  @@index([origin])
  // Trigram GIN index → fast ILIKE '%term%' for the admin list's client search.
  @@index([clientName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("appointments")
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  serviceName   String?     // name snapshot at booking time (preserves history if the service is renamed/deleted)
  price         Int         // price at time of booking (snapshot)
  // Per-line discount (optional). Mutually exclusive with the appointment's
  // total discount: the UI/API allow per-service discounts OR a total, never both.
  descuentoTipo   DiscountType?
  descuentoValor  Int?          // % (0–100) or fixed COP, per descuentoTipo
  descuentoMotivo String?       // internal, optional
  // Extras tied to this service line.
  extras        AppointmentExtra[]
  @@unique([appointmentId, serviceId])
  // Trigram GIN index → fast ILIKE '%term%' for the admin list's service search.
  @@index([serviceName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("appointment_services")
}

// Extra: a product or extra service added to an appointment (manual or public),
// with its own description and amount. An appointment can have several.
model AppointmentExtra {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  // Optional link to a service line: an extra "belonging to that service".
  // Null = general appointment-level extra (previous behavior).
  appointmentServiceId String?
  appointmentService   AppointmentService? @relation(fields: [appointmentServiceId], references: [id], onDelete: Cascade)
  description   String
  amount        Int         // in Colombian pesos
  createdAt     DateTime    @default(now())
  @@index([appointmentId])
  @@index([appointmentServiceId])
  @@map("appointment_extras")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  ONLINE
  WHATSAPP
  TELEFONO
  PRESENCIAL
}

enum AppointmentOrigin {
  PUBLIC   // client self-booked via the public flow
  MANUAL   // admin created ("Cita próxima")
  VIP      // multi-service package booking
  PAST     // retroactively registered ("Cita pasada")
}

enum PaymentStatus {
  PENDING   // no payment recorded
  PAID      // paid in full
  PARTIAL   // partial payment / deposit
  WAIVED    // courtesy / no charge
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  NEQUI
  DAVIPLATA
}

enum DiscountType {
  PORCENTAJE  // descuentoValor = 0–100 (%)
  VALOR_FIJO  // descuentoValor = COP
}

// ─────────────────────────────────────────
// SCHEDULES AND BLOCKED DATES
// ─────────────────────────────────────────

model Schedule {
  id        String    @id @default(cuid())
  dayOfWeek DayOfWeek @unique
  startTime String
  endTime   String
  // Optional lunch break within the day (e.g. 12:00–14:00). Slots overlapping
  // it are not offered. Both null = continuous day, no break.
  breakStart String?
  breakEnd   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@map("schedules")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
  @@index([date])
  @@map("blocked_dates")
}

// ─────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  description String
  amount      Int             // in Colombian pesos
  date        DateTime
  category    ExpenseCategory @default(OTROS)
  notes       String?
  // Soft delete: the expense disappears from lists and accounting but the row
  // persists, so financial history is never lost.
  deletedAt   DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([date])
  @@index([category])
  @@index([deletedAt])
  @@map("expenses")
}

enum ExpenseCategory {
  INSUMOS     // nail polish, gels, adhesives, etc.
  EQUIPOS     // tools, lamps, etc.
  SERVICIOS   // electricity, internet, platforms
  ARRIENDO
  MARKETING
  OTROS
}

// ─────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────

model GalleryImage {
  id          String           @id @default(cuid())
  title       String?
  description String?
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  s3Key       String           @unique
  width       Int?
  height      Int?
  order       Int              @default(0)
  isActive    Boolean          @default(true)
  // CSS object-position for the public cover crop, e.g. "top left" | "center center".
  // Existing rows default to center → no visual change until edited.
  focalPoint  String           @default("center center")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@index([isActive])
  @@index([categoryId])
  @@map("gallery_images")
}

// ─────────────────────────────────────────
// HERO
// Homepage banner carousel images — managed from the admin (S3 + DB) so they can
// change without a rebuild. Distinct from GalleryImage (portfolio grid): fewer,
// curated, no captions. Ordered by `order`; focalPoint drives the hard crop.
// ─────────────────────────────────────────

model HeroImage {
  id         String   @id @default(cuid())
  s3Key      String   @unique
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  // CSS object-position for the banner crop (the hero crops hard to a landscape).
  focalPoint String   @default("center center")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([isActive])
  @@map("hero_images")
}

// ─────────────────────────────────────────
// TESTIMONIALS
// Reviews shown on the landing page. Created by the admin (source ADMIN) or,
// in the future, submitted by clients (source CLIENT) → left in PENDING for
// moderation. isActive = show/hide; deletedAt = soft delete.
// ─────────────────────────────────────────

model Testimonial {
  id              String            @id @default(cuid())
  clientName      String
  initials        String            // auto-generated from the name ("Carmen Morales" → "C.M.")
  type            String            // "Clienta frecuente", "Clienta VIP", or free text
  text            String
  stars           Int               @default(5)
  imageUrl        String?           // public (S3) URL of the work photo
  imageKey        String?           // S3 key, to be able to delete/replace the object
  isActive        Boolean           @default(true)
  order           Int               @default(0)
  // Moderation
  source          TestimonialSource @default(ADMIN)
  status          TestimonialStatus @default(APPROVED)
  appointmentId   String?           // optional relation to a real appointment
  clientEmail     String?           // for contact if needed
  rejectionReason String?           // internal note if rejected
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@index([order])
  @@map("testimonials")
}

enum TestimonialSource {
  ADMIN
  CLIENT
}

enum TestimonialStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────

model AuditLog {
  id          String       @id @default(cuid())
  action      AuditAction
  entity      AuditEntity
  entityId    String
  actorType   AuditActor?  // ADMIN | CLIENT | SYSTEM (null = legacy rows)
  userEmail   String?      // admin who performed it (or the email attempted on a failed login)
  ip          String?
  userAgent   String?      // device/browser
  before      Json?        // previous state (edits, status changes, cancellations)
  after       Json?        // new state
  description String?      // human-readable text: "Admin marcó la cita de Juan Pérez como pagada"
  metadata    Json?        // extra context
  createdAt   DateTime     @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userEmail])
  @@index([actorType])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// RATE LIMITING (shared across pods)
// Fixed-window counters in Postgres so the limit stays consistent under the 2+
// replicas the app runs with (deployment.yaml replicas: 2 + HPA). Replaces the
// old per-pod in-memory Maps, which multiplied the effective limit per replica.
// ─────────────────────────────────────────
model RateLimit {
  key     String   @id           // e.g. "booking:1.2.3.4", "login:1.2.3.4"
  count   Int      @default(0)
  resetAt DateTime               // end of the current window
  @@index([resetAt])            // for cleanup of expired rows
  @@map("rate_limits")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  CANCEL
  LOGIN
  LOGIN_FAILED
  LOGOUT
  EMAIL_SENT
  EMAIL_FAILED
  EXPORT        // audit-log export (reading/exfiltrating the trace is itself an event)
}

enum AuditEntity {
  APPOINTMENT
  CLIENT
  EXPENSE
  SERVICE
  CATEGORY
  GALLERY
  SCHEDULE
  PROFESSIONAL
  TESTIMONIAL
  AUTH
  EMAIL
}

enum AuditActor {
  ADMIN
  CLIENT
  SYSTEM
}
