// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pg_trgm powers the GIN indexes that accelerate the admin list's ILIKE search.
  extensions = [pg_trgm]
}

// ─────────────────────────────────────────
// USUARIOS (admin)
// ─────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  // Deactivated admins can't log in and their active sessions are invalidated,
  // but the row persists so audit history keeps their name.
  isActive  Boolean  @default(true)
  // Last successful login (shown in the admin-management list).
  lastLoginAt DateTime?
  // Bumped on every password change; embedded in the JWT so tokens issued
  // before the change are rejected → forces re-login on other devices.
  passwordChangedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// ─────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────

model Client {
  id           String        @id @default(cuid())
  name         String
  // Optional: in Postgres a unique index allows multiple NULLs, so several
  // clients without email never collide, while real emails stay unique.
  email        String?       @unique
  phone        String?
  notes        String?       // alergias, preferencias, observaciones internas
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  @@index([email])
  @@map("clients")
}

// ─────────────────────────────────────────
// CATEGORÍAS DE SERVICIO
// Antes eran un enum hardcodeado; ahora viven en DB para poder
// crearlas/editarlas/eliminarlas desde el panel admin sin tocar código.
// `slug` es la clave estable usada en URLs (?categoria=...) y agrupación.
// `icon` guarda la clave de un set de íconos predefinidos (ver ICON_KEYS).
// Soft delete: nunca se borran físicamente para no romper el historial.
// ─────────────────────────────────────────

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  slug          String         @unique
  description   String?
  icon          String         @default("promo")
  order         Int            @default(0)
  isActive      Boolean        @default(true)
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  services      Service[]
  galleryImages GalleryImage[]
  @@index([isActive])
  @@index([deletedAt])
  @@map("categories")
}

// ─────────────────────────────────────────
// SERVICIOS
// ─────────────────────────────────────────

model Service {
  id              String              @id @default(cuid())
  name            String              @unique
  description     String?
  categoryId      String?
  category        Category?           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  price           Int
  durationMinutes Int
  isActive        Boolean             @default(true)
  order           Int                 @default(0)
  // Soft delete: el servicio desaparece del catálogo pero la fila persiste,
  // de modo que las citas históricas mantienen su referencia y nombre.
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  appointments    Appointment[]
  appointmentServices AppointmentService[]
  @@index([categoryId])
  @@index([deletedAt])
  @@map("services")
}

// ─────────────────────────────────────────
// DESCUENTO VIP (multi-servicio)
// Regla parametrizable: a partir de N servicios seleccionados
// en una misma cita (de cualquier categoría), se aplica un
// porcentaje de descuento por tramos. Editable desde el panel
// admin, sin tocar código.
// ─────────────────────────────────────────

model VipDiscountConfig {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  @@map("vip_discount_config")
}

model VipDiscountTier {
  id          String @id @default(cuid())
  minServices Int    @unique // a partir de cuántos servicios aplica este tramo
  discountPct Int    // porcentaje de descuento (0-100)
  @@map("vip_discount_tiers")
}

// ─────────────────────────────────────────
// PROFESIONALES
// Cada profesional puede atender una cita a la vez; la capacidad
// total del estudio en un horario = número de profesionales activos
// sin una cita que se superponga en ese rango.
// ─────────────────────────────────────────

model Professional {
  id           String        @id @default(cuid())
  name         String
  specialty    String?
  rating       Float         @default(5.0)
  reviewCount  Int           @default(0)
  isActive     Boolean       @default(true)
  order        Int           @default(0)
  // Soft delete: a deleted professional disappears from the admin list, the
  // public booking flow and availability, but the row persists so historical
  // appointments keep their professionalId reference intact.
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  @@index([isActive])
  @@index([deletedAt])
  @@map("professionals")
}

// Toggle (singleton): whether /agendar lets the client pick a professional.
// When off, the booking form never sends professionalId — the existing
// "Primera disponible" auto-assignment in /api/appointments already covers it.
model BookingSettings {
  id                  String   @id @default(cuid())
  showProfessionalStep Boolean @default(false)
  // How many days into the future clients can book (booking horizon).
  // Drives the date strip in /agendar. Editable from the admin (7–365).
  maxAdvanceDays      Int      @default(90)
  updatedAt           DateTime @updatedAt
  @@map("booking_settings")
}

// ─────────────────────────────────────────
// MÉTRICAS DEL LANDING (singleton)
// Indicadores numéricos del Home/Nosotros, editables desde el panel admin
// para no tocar código. `servicesCount` NO se guarda aquí: se deriva en vivo
// del catálogo (servicios activos) para que nunca se desincronice.
// ─────────────────────────────────────────
model LandingStats {
  id                String   @id @default(cuid())
  appointmentsCount Int      @default(300) // "+300 Citas realizadas"
  clientsCount      Int      @default(180) // "+180 Clientas satisfechas"
  yearsExperience   Int      @default(3)   // "+3 Años de experiencia"
  rating            Float    @default(4.8) // "4.8★ Calificación"
  updatedAt         DateTime @updatedAt
  @@map("landing_stats")
}

// ─────────────────────────────────────────
// CITAS
// ─────────────────────────────────────────

model Appointment {
  id                 String            @id @default(cuid())
  // Datos del cliente (desnormalizados para no perder info si el cliente cambia)
  clientName         String
  clientEmail        String?
  clientPhone        String
  // Referencia al perfil de cliente (opcional: se une automáticamente si existe)
  clientId           String?
  client             Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  serviceId          String            // primary service (always set for backward compat)
  service            Service           @relation(fields: [serviceId], references: [id])
  services           AppointmentService[] // all services (for multi-service VIP bookings)
  totalDurationMinutes Int             // sum of all service durations
  discountPercent    Int               @default(0) // % de descuento VIP aplicado (snapshot al confirmar)
  // Profesional asignado. Null = se eligió "Primera disponible" pero no se
  // pudo determinar (no debería ocurrir en flujo normal; el servidor asigna
  // el primer profesional libre en el momento de crear la cita).
  professionalId     String?
  professional       Professional?     @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  date               DateTime
  startTime          String
  endTime            String
  status             AppointmentStatus @default(PENDING)
  // Origen de la cita
  source             AppointmentSource @default(ONLINE)
  // Provenance, set explicitly at creation (no field-combination heuristics):
  // PUBLIC = client self-booked, MANUAL = admin "Cita próxima", VIP = multi-
  // service package, PAST = retroactive "Cita pasada". Legacy rows backfilled
  // in the migration (source != ONLINE → MANUAL, else PUBLIC).
  origin             AppointmentOrigin @default(PUBLIC)
  // Pago
  paymentStatus      PaymentStatus     @default(PENDING)
  paymentMethod      PaymentMethod?
  amountPaid         Int?              // en pesos colombianos
  // Adicionales: cargos extra sobre el precio del servicio (productos,
  // servicios extra). Múltiples por cita, editables desde el detalle.
  extras             AppointmentExtra[]
  // Descuento manual aplicado por el admin (citas manuales). Independiente del
  // discountPercent VIP del flujo público. precioFinal = subtotal − descuento.
  descuentoTipo      DiscountType?     // null = sin descuento
  descuentoValor     Int?              // % (0–100) o COP fijo, según descuentoTipo
  descuentoMotivo    String?           // interno, opcional (ej. "Cliente frecuente")
  precioFinal        Int?              // total a cobrar tras descuento (snapshot, COP)
  notes              String?
  cancelToken        String            @unique @default(cuid())
  calendarEventId    String?
  confirmationSentAt DateTime?
  reminderSentAt     DateTime?
  reminder2hSentAt   DateTime?
  followUpSentAt     DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  @@index([date])
  @@index([clientEmail])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
  @@index([professionalId])
  @@index([origin])
  // Trigram GIN index → fast ILIKE '%term%' for the admin list's client search.
  @@index([clientName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("appointments")
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])
  serviceName   String?     // snapshot del nombre al reservar (preserva el historial si el servicio se renombra/elimina)
  price         Int         // price at time of booking (snapshot)
  @@unique([appointmentId, serviceId])
  // Trigram GIN index → fast ILIKE '%term%' for the admin list's service search.
  @@index([serviceName(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("appointment_services")
}

// Adicional: producto o servicio extra agregado a una cita (manual o pública),
// con su propia descripción y valor. Una cita puede tener varios.
model AppointmentExtra {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  description   String
  amount        Int         // en pesos colombianos
  createdAt     DateTime    @default(now())
  @@index([appointmentId])
  @@map("appointment_extras")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  ONLINE
  WHATSAPP
  TELEFONO
  PRESENCIAL
}

enum AppointmentOrigin {
  PUBLIC   // client self-booked via the public flow
  MANUAL   // admin created ("Cita próxima")
  VIP      // multi-service package booking
  PAST     // retroactively registered ("Cita pasada")
}

enum PaymentStatus {
  PENDING   // sin registrar pago
  PAID      // pagado completo
  PARTIAL   // pago parcial / abono
  WAIVED    // cortesía / sin cobro
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  NEQUI
  DAVIPLATA
}

enum DiscountType {
  PORCENTAJE  // descuentoValor = 0–100 (%)
  VALOR_FIJO  // descuentoValor = COP
}

// ─────────────────────────────────────────
// HORARIOS Y FECHAS BLOQUEADAS
// ─────────────────────────────────────────

model Schedule {
  id        String    @id @default(cuid())
  dayOfWeek DayOfWeek @unique
  startTime String
  endTime   String
  // Optional lunch break within the day (e.g. 12:00–14:00). Slots overlapping
  // it are not offered. Both null = continuous day, no break.
  breakStart String?
  breakEnd   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  @@map("schedules")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
  @@index([date])
  @@map("blocked_dates")
}

// ─────────────────────────────────────────
// GASTOS
// ─────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  description String
  amount      Int             // en pesos colombianos
  date        DateTime
  category    ExpenseCategory @default(OTROS)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([date])
  @@index([category])
  @@map("expenses")
}

enum ExpenseCategory {
  INSUMOS     // esmaltes, geles, adhesivos, etc.
  EQUIPOS     // herramientas, lámparas, etc.
  SERVICIOS   // luz, internet, plataformas
  ARRIENDO
  MARKETING
  OTROS
}

// ─────────────────────────────────────────
// GALERÍA
// ─────────────────────────────────────────

model GalleryImage {
  id          String           @id @default(cuid())
  title       String?
  description String?
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  s3Key       String           @unique
  width       Int?
  height      Int?
  order       Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@index([isActive])
  @@index([categoryId])
  @@map("gallery_images")
}

// ─────────────────────────────────────────
// TESTIMONIOS
// Reseñas mostradas en la landing. Creadas por el admin (source ADMIN) o,
// a futuro, enviadas por clientas (source CLIENT) → quedan en PENDING para
// moderación. isActive = mostrar/ocultar; deletedAt = soft delete.
// ─────────────────────────────────────────

model Testimonial {
  id              String            @id @default(cuid())
  clientName      String
  initials        String            // auto-generadas del nombre ("Carmen Morales" → "C.M.")
  type            String            // "Clienta frecuente", "Clienta VIP", o texto libre
  text            String
  stars           Int               @default(5)
  imageUrl        String?           // URL pública (S3) de la foto del trabajo
  imageKey        String?           // key S3, para poder borrar/reemplazar el objeto
  isActive        Boolean           @default(true)
  order           Int               @default(0)
  // Moderación
  source          TestimonialSource @default(ADMIN)
  status          TestimonialStatus @default(APPROVED)
  appointmentId   String?           // relación opcional con una cita real
  clientEmail     String?           // para contacto si hace falta
  rejectionReason String?           // nota interna si se rechaza
  // Soft delete
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  @@index([isActive])
  @@index([status])
  @@index([deletedAt])
  @@index([order])
  @@map("testimonials")
}

enum TestimonialSource {
  ADMIN
  CLIENT
}

enum TestimonialStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────
// AUDITORÍA
// ─────────────────────────────────────────

model AuditLog {
  id          String       @id @default(cuid())
  action      AuditAction
  entity      AuditEntity
  entityId    String
  actorType   AuditActor?  // ADMIN | CLIENT | SYSTEM (null = registros legacy)
  userEmail   String?      // admin que ejecutó (o email intentado en login fallido)
  ip          String?
  userAgent   String?      // dispositivo/navegador
  before      Json?        // estado previo (ediciones, cambios de estado, cancelaciones)
  after       Json?        // estado nuevo
  description String?      // texto legible: "Admin marcó la cita de Juan Pérez como pagada"
  metadata    Json?        // contexto extra
  createdAt   DateTime     @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userEmail])
  @@index([actorType])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  CANCEL
  LOGIN
  LOGIN_FAILED
  LOGOUT
  EMAIL_SENT
  EMAIL_FAILED
  EXPORT        // audit-log export (reading/exfiltrating the trace is itself an event)
}

enum AuditEntity {
  APPOINTMENT
  CLIENT
  EXPENSE
  SERVICE
  CATEGORY
  GALLERY
  SCHEDULE
  PROFESSIONAL
  TESTIMONIAL
  AUTH
  EMAIL
}

enum AuditActor {
  ADMIN
  CLIENT
  SYSTEM
}
