# ── Dependencias ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js ────────────────────────────────────────────────────
.next/
out/
build/

# ── Variables de entorno — NUNCA commitear ─────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Sí commitear (plantilla sin valores reales):
# .env.example  ← NO ignorar

# ── Prisma ─────────────────────────────────────────────────────
# Las migraciones SÍ se commitean
# Solo ignorar el cliente generado
prisma/generated/

# ── Docker ─────────────────────────────────────────────────────
# No ignorar Dockerfile ni docker-compose.yml
# Solo ignorar overrides locales
docker-compose.override.yml

# ── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/var/log/

# ── Sistema operativo ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ── TypeScript ─────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Terraform ──────────────────────────────────────────────────
# Directorios de trabajo y binarios de providers (pesados, se regeneran con `terraform init`)
**/.terraform/*
# Estado — NUNCA commitear (puede contener secretos)
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
# Variables con valores reales — commitear solo *.tfvars.example
*.tfvars
*.tfvars.json
# Logs de crash de Terraform
crash.log
crash.*.log
# SÍ se commitea el lock de providers para builds reproducibles:
!**/.terraform.lock.hcl

# ── Misc ───────────────────────────────────────────────────────
.vercel
.turbo