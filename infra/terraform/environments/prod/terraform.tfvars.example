region      = "us-east-1"
name_prefix = "appointment-scheduling-prod"

github_owner = "ortizJorge096"
github_repo  = "Appointment-Scheduling-Next.js"

allowed_branches     = ["main", "develop"]
allowed_environments = ["dev", "production"]

# IMPORTANTE: en prod por defecto NO crea el provider (lo creó dev).
create_oidc_provider = false

git_branch        = "main"
kustomize_overlay = "prod"

# Hostname público de prod (A record → EIP). Lo lee el CI desde SSM para fijar
# el host del ingress, NEXTAUTH_URL y NEXT_PUBLIC_APP_URL.
app_host = "vjbeautystudio.com"

image_ref = ""

enable_ec2_k3s    = true

# Alertas/monitoring APAGADAS por elección del negocio (sin CloudWatch alarms ni SNS).
enable_monitoring = false

# Backups: el módulo AWS Backup (vault 30/90/365 días) queda APAGADO.
# La BD conserva 7 días de point-in-time recovery gratis (ver backup_retention_days en main.tf).
enable_aws_backup = false

alarm_email = ""

github_token = ""

# t3.medium NO es Free Tier (~$30/mes). Si quieres mantenerlo Free, ponlo en t3.micro
# y reduce HPA a 1 réplica (perderás HA).
instance_type       = "t3.medium"
spot_instance_types = ["t3.medium", "t3a.medium", "t3.large"]

runner_labels = "self-hosted,linux,x64,k3s-deploy,k3s-prod"

# Let's Encrypt + nip.io: cert real, sin dominio propio.
enable_letsencrypt = true
letsencrypt_email  = ""

# SES — verifica el remitente en consola SES antes de activar.
ses_from_email = "noreply@tu-dominio.com"
enable_emails  = true

# Protección contra borrado accidental de la BD.
db_deletion_protection = true
db_skip_final_snapshot = false

# RDS scheduler (apaga/enciende la BD por horario para ahorrar). Off por ahora;
# ponlo en true cuando quieras activarlo. Horarios en cron + timezone:
enable_rds_scheduler  = false
rds_stop_schedule     = "cron(0 23 * * ? *)"   # apaga 23:00
rds_start_schedule    = "cron(0 6 * * ? *)"    # enciende 06:00 ("" = sin auto-encendido)
rds_schedule_timezone = "America/Bogota"
