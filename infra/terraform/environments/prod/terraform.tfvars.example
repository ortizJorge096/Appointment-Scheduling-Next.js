region      = "us-east-1"
name_prefix = "appointment-scheduling-prod"

github_owner = "ortizJorge096"
github_repo  = "Appointment-Scheduling-Next.js"

allowed_branches     = ["main", "develop"]
allowed_environments = ["dev", "production"]

# IMPORTANTE: en prod por defecto NO crea el provider (lo creó dev).
create_oidc_provider = false

git_branch        = "main"
kustomize_overlay = "prod"

image_ref = ""

enable_ec2_k3s    = true
enable_monitoring = true

alarm_email = ""

github_token = ""

# t3.medium NO es Free Tier (~$30/mes). Si quieres mantenerlo Free, ponlo en t3.micro
# y reduce HPA a 1 réplica (perderás HA).
instance_type       = "t3.medium"
spot_instance_types = ["t3.medium", "t3a.medium", "t3.large"]

runner_labels = "self-hosted,linux,x64,k3s-deploy,k3s-prod"

# Let's Encrypt + nip.io: cert real, sin dominio propio.
enable_letsencrypt = true
letsencrypt_email  = ""

# SES — verifica el remitente en consola SES antes de activar.
ses_from_email = "noreply@tu-dominio.com"
enable_emails  = true

# Protección contra borrado accidental de la BD.
db_deletion_protection = true
db_skip_final_snapshot = false
